# Clearview Savings — environment variables
#
# Copy this file to `.env.local` and fill in real values. `.env.local`
# is gitignored; never commit real secrets. Variables prefixed with
# NEXT_PUBLIC_ are exposed to the browser by design — keep everything
# else server-only.

# ── Database (Supabase Postgres) ─────────────────────────────────────
# Pooled connection string from the Supabase project settings.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# ── Supabase Auth / client ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Privileged service key — used only for MFA recovery (see lib/supabase/admin.ts).
SUPABASE_SECRET_KEY=sb_secret_...

# Absolute base URL of the deployed app, used to build links in auth emails.
APP_BASE_URL=http://localhost:3000

# Shared secret for the Supabase Auth "send email" hook (see app/api/auth/email-hook).
SUPABASE_AUTH_HOOK_SECRET=whsec_...

# ── Bot protection (Cloudflare Turnstile) ────────────────────────────
# Only the SITE key lives here. The Turnstile SECRET is configured in the
# Supabase dashboard — Supabase is the sole verifier of the token (ADR 0003).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
# Server-side Turnstile secret. Used by the Supabase token verifier; keep it
# out of the client bundle and out of git.
TURNSTILE_SECRET_KEY=0x...

# ── Transactional email (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_...
# Caregiver-side operational alerts (sign-up notifications, daily digest).
ADMIN_EMAIL=you@example.com

# ── Rate limiting (Upstash Redis) ────────────────────────────────────
# Optional in local dev (the per-IP limiter is bypassed off-production).
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── Cron (Vercel) ────────────────────────────────────────────────────
# Bearer secret required by the daily-digest cron route.
CRON_SECRET=...

# ── Observability (Sentry) — optional ────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_WEBHOOK_SECRET=

# ── Support / donations (caregiver footer) — optional ────────────────
# Your Ko-fi page URL. When set, a quiet "Support this project" link
# appears in the caregiver-side footer only (never patient-facing).
# Leave blank to hide the link entirely.
NEXT_PUBLIC_KOFI_URL=https://ko-fi.com/YOUR-HANDLE

# ── Seed script (dev only) ───────────────────────────────────────────
# Credentials for the demo caregiver created by `pnpm seed`.
CLEARVIEW_SAVINGS_DEMO_EMAIL=demo@example.com
CLEARVIEW_SAVINGS_DEMO_PASSWORD=change-me
